# ---- Unity固有 ----
# LightingData.asset はテキストだが巨大になるため LFS 推奨
*.asset filter=lfs diff=lfs merge=lfs -text binary

# ---- テキスト扱いの固定（改行統一） ----
# Unityが生成するメタファイル・シリアライズファイルは diff を取れる形で管理する
*.meta -filter -diff -merge text eol=lf
*.unity -filter -diff -merge text eol=lf
*.prefab -filter -diff -merge text eol=lf
*.mat -filter -diff -merge text eol=lf
*.anim -filter -diff -merge text eol=lf
*.controller -filter -diff -merge text eol=lf
*.physicMaterial -filter -diff -merge text eol=lf
*.physicsMaterial2D -filter -diff -merge text eol=lf
*.playable -filter -diff -merge text eol=lf
*.mask -filter -diff -merge text eol=lf
*.brush -filter -diff -merge text eol=lf
*.flare -filter -diff -merge text eol=lf
*.fontsettings -filter -diff -merge text eol=lf
*.guiskin -filter -diff -merge text eol=lf
*.giparams -filter -diff -merge text eol=lf
*.renderTexture -filter -diff -merge text eol=lf
*.spriteatlas -filter -diff -merge text eol=lf
*.terrainlayer -filter -diff -merge text eol=lf
*.mixer -filter -diff -merge text eol=lf
*.shadervariants -filter -diff -merge text eol=lf

